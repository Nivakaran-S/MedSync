# ============================================================================
# MedSync — Centralized Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ============================================================================

# --- Platform Secrets ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d
# Shared secret for service-to-service calls (payment → appointment payment-status update).
# Must be the SAME value across appointment + payment services.
INTERNAL_API_KEY=change_me_to_a_long_random_string

# --- Admin bootstrap (seeded into auth DB on first boot) ---
ADMIN_EMAIL=admin@medsync.com
ADMIN_PASSWORD=change_me_strong_password

# --- Messaging / Cache ---
KAFKA_BROKERS=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379

# --- MongoDB (Atlas — REQUIRED) ---
# Each service appends its own database name (e.g. /patient_db) to MONGO_BASE.
# Use the SRV form from MongoDB Atlas → "Connect your application":
#   mongodb+srv://<user>:<password>@<cluster>.<id>.mongodb.net?retryWrites=true&w=majority
#
# Notes:
#  • The DB name is appended automatically by each service (do NOT include /myDb).
#  • For local dev without Atlas, run `docker compose --profile local-mongo up`
#    and set MONGO_BASE=mongodb://mongo:27017 instead.
MONGO_BASE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net?retryWrites=true&w=majority

# --- Cross-service URLs (Docker network — service names, not localhost) ---
DOCTOR_SERVICE_URL=http://doctor-management:3002
APPOINTMENT_SERVICE_URL=http://appointment:3003
FRONTEND_URL=http://localhost:3000

# --- Internal service URLs (used by auth health aggregator) ---
PATIENT_SERVICE_URL=http://patient-management:3001
TELEMEDICINE_SERVICE_URL=http://telemedicine:3004
PAYMENT_SERVICE_URL=http://payment:3005
NOTIFICATION_SERVICE_URL=http://notification:3006
AI_SERVICE_URL=http://ai-symptom-checker:3007

# --- AI Symptom Checker (Google Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Payment Service (Stripe) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Telemedicine Service (Agora) ---
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# --- Notification Service (Email via SMTP) ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Notification Service (Twilio SMS — optional, logs to console if unset) ---
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=your_twilio_phone_number

# --- Service Ports (host mappings) ---
AUTH_PORT=5000
PATIENT_PORT=3001
DOCTOR_PORT=3002
APPOINTMENT_PORT=3003
TELEMEDICINE_PORT=3004
PAYMENT_PORT=3005
NOTIFICATION_PORT=3006
AI_PORT=3007
FRONTEND_PORT=3000

# --- Frontend (NEXT_PUBLIC_* — browser reads these) ---
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:5000/api/auth
NEXT_PUBLIC_PATIENT_SERVICE_URL=http://localhost:3001/api/patients
NEXT_PUBLIC_DOCTOR_SERVICE_URL=http://localhost:3002/api/doctors
NEXT_PUBLIC_APPOINTMENT_SERVICE_URL=http://localhost:3003/api/appointments
NEXT_PUBLIC_TELEMEDICINE_SERVICE_URL=http://localhost:3004/api/sessions
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost:3005/api/payments
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:3006/api/notify
NEXT_PUBLIC_SYMPTOM_CHECKER_URL=http://localhost:3007/api/symptom-checker
